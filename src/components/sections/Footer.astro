---
import { Image } from "astro:assets";
import Wrapper from "../Wrapper.astro";
import logo from "../../assets/logo/mrperu-logo-transparent.webp";
import linkedin from "../../assets/linkedin.svg";
import youtube from "../../assets/youtube.svg";
import facebook from "../../assets/facebook.svg";
import instagram from "../../assets/instagram.svg";

const year = new Date().getFullYear();
const whatsappLink = "https://api.whatsapp.com/send/?phone=51997580486&text&type=phone_number&app_absent=0";

const firstNavList = [
    {
        text: "Nosotros",
        href: "#about-us",
        external: false,
    },
    {
        text: "Productos",
        href: "#products",
        external: false,
    },
    {
        text: "Servicios",
        href: "#services",
        external: false,
    },
    {
        text: "Alquileres",
        href: "#rent",
        external: false,
    },
    {
        text: "Contacto",
        href: "#contact",
        external: false,
    },
    {
        text: "Blog",
        href: "https://www.google.com",
        external: true,
    },
];

const secondNavList = [
    {
        text: "Alquiler de Compresores",
        href: "",
        external: true
    },
    {
        text: "Compresores de Aire",
        href: "",
        external: true
    },
    {
        text: "Secadores de Aire",
        href: "",
        external: true
    },
    {
        text: "Filtros de Aire",
        href: "",
        external: true
    },
    {
        text: "Tratamiento de Condensados",
        href: "",
        external: true
    },
    {
        text: "Purgadores Automáticos",
        href: "",
        external: true
    },
];
---

<footer class="bg-blue-mrperu pt-12 pb-4 sm:pt-16 lg:pt-20">
    <Wrapper>
        <div class="flex flex-col gap-10 sm:gap-12 lg:flex-row lg:gap-20 xl:gap-32">
            <div class="flex flex-col items-center text-center lg:items-start lg:text-left">
                <Image
                    src={logo}
                    alt="Logo MR Perú"
                    width={130}
                    class="mx-auto lg:mx-0"
                />
                <div class="mt-3 flex flex-wrap justify-center gap-2 lg:justify-start">
                    <a href="https://www.linkedin.com/company/mr-peru/" target="_blank">
                        <Image
                            src={linkedin}
                            alt="LinkedIn MR Perú"
                            width={35}
                        />
                    </a>
                    <a href="https://www.youtube.com/channel/UCj4O2oqRBZ7I4AiU0D0A3lw" target="_blank">
                        <Image src={youtube} alt="Youtube MR Perú" width={35} />
                    </a>
                    <a href="https://www.facebook.com/compresoras" target="_blank">
                        <Image
                            src={facebook}
                            alt="Facebook MR Perú"
                            width={35}
                        />
                    </a>
                    <a href="" target="_blank">
                        <Image
                            src={instagram}
                            alt="Instagram MR Perú"
                            width={35}
                        />
                    </a>
                </div>
            </div>
            <ul class="flex flex-col gap-3 text-center sm:gap-4 lg:text-left">
                { firstNavList.map((item) => (
                    <li>
                        <a
                            href={item.href}
                            target={`${item.external ? "_blank" : "_self"}`}
                            class="text-base font-semibold text-white sm:text-lg"
                        >
                            {item.text}
                        </a>
                    </li>
                )) }
            </ul>
            <ul class="flex flex-col gap-3 text-center font-semibold sm:gap-4 lg:text-left">
                { secondNavList.map((item) => (
                    <li>
                        <a
                            href={item.href}
                            target={`${item.external ? "_blank" : "_self"}`}
                            class="text-base text-white sm:text-lg"
                        >
                            {item.text}
                        </a>
                    </li>
                )) }
            </ul>
        </div>
        <p class="mt-10 text-center text-sm text-white sm:mt-12 sm:text-base">
            © {year} MR Perú. Todos los derechos reservados.
        </p>
    </Wrapper>

</footer>

<a
  href={whatsappLink}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Escríbenos por WhatsApp"
  class="fixed bottom-5 right-5 z-[90] inline-flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-white shadow-[0_12px_28px_rgba(0,0,0,0.22)] transition hover:scale-105 hover:shadow-[0_16px_34px_rgba(0,0,0,0.26)] sm:bottom-6 sm:right-6 sm:h-16 sm:w-16"
>
  <svg width="30" height="30" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path fill="currentColor" d="M19.11 17.2c-.26-.13-1.52-.75-1.76-.83-.23-.09-.4-.13-.57.13-.17.26-.66.83-.8 1-.14.17-.29.2-.55.07-.26-.13-1.08-.4-2.06-1.27-.76-.68-1.27-1.52-1.42-1.78-.14-.26-.02-.4.11-.53.12-.12.26-.29.39-.43.13-.14.17-.23.26-.39.09-.17.04-.3-.02-.43-.07-.13-.57-1.38-.78-1.89-.21-.5-.42-.43-.57-.44h-.48c-.17 0-.43.07-.66.33-.23.26-.87.85-.87 2.06 0 1.2.89 2.37 1.01 2.53.13.17 1.75 2.67 4.25 3.74.59.26 1.05.42 1.41.54.59.19 1.13.16 1.56.1.48-.07 1.52-.62 1.74-1.21.22-.59.22-1.09.15-1.2-.06-.11-.23-.17-.49-.3Z"/>
    <path fill="currentColor" fill-rule="evenodd" clip-rule="evenodd" d="M16 .89C7.66.89.89 7.66.89 16c0 2.66.7 5.26 2.02 7.55L.98 31.11l7.75-1.87A15.03 15.03 0 0 0 16 31.11c8.34 0 15.11-6.77 15.11-15.11C31.11 7.66 24.34.89 16 .89Zm0 27.56c-2.33 0-4.62-.63-6.62-1.82l-.47-.28-4.6 1.11 1.12-4.49-.31-.46a12.34 12.34 0 0 1-1.9-6.51C3.22 9.01 9.01 3.22 16 3.22S28.78 9.01 28.78 16 22.99 28.45 16 28.45Zm6.78-9.28c-.37-.18-2.18-1.08-2.52-1.2-.34-.12-.59-.18-.84.18-.25.37-.96 1.2-1.18 1.45-.22.24-.43.27-.8.09-.37-.18-1.56-.58-2.98-1.85-1.1-.98-1.84-2.19-2.05-2.56-.21-.37-.02-.57.16-.75.16-.16.37-.43.55-.64.18-.21.24-.37.37-.61.12-.24.06-.46-.03-.64-.09-.18-.84-2.03-1.15-2.77-.3-.72-.61-.63-.84-.64l-.72-.01c-.24 0-.64.09-.97.46-.34.37-1.28 1.25-1.28 3.04 0 1.79 1.31 3.52 1.49 3.76.19.24 2.58 3.94 6.25 5.52.87.37 1.55.59 2.08.76.88.28 1.68.24 2.31.15.7-.1 2.18-.89 2.49-1.75.31-.86.31-1.6.22-1.75-.09-.15-.34-.24-.71-.43Z"/>
  </svg>
</a>
